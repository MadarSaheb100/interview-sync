      "position": [
        1232,
        624
      ]
    },
    {
      "parameters": {
        "jsCode": "const analysis = $input.first().json.output;\n\nconst urgencyEmoji = {\n  high: '🚨',\n  medium: '⚠️',\n  low: 'ℹ️'\n};\n\nconst typeLabels = {\n  interviewer_unavailable: 'Interviewer Unavailable',\n  room_issue: 'Room Issue',\n  candidate_delay: 'Candidate Delay',\n  other: 'Schedule Change'\n};\n\nlet response = `${urgencyEmoji[analysis.urgency] || '📋'} **${typeLabels[analysis.disruptionType] || 'Disruption Detected'}**\\n\\n`;\n\nif (analysis.affectedCandidates?.length > 0) {\n  response += `**Affected Candidates:** ${analysis.affectedCandidates.join(', ')}\\n`;\n}\n\nif (analysis.affectedInterviewers?.length > 0) {\n  response += `**Affected Interviewers:** ${analysis.affectedInterviewers.join(', ')}\\n`;\n}\n\nif (analysis.affectedRooms?.length > 0) {\n  response += `**Affected Rooms:** ${analysis.affectedRooms.join(', ')}\\n`;\n}\n\nresponse += `\\n**Solution:**\\n${analysis.proposedSolution}\\n\\n`;\n\nif (analysis.notificationNeeded) {\n  response += '✅ Notifications sent to all affected parties.\\n';\n}\n\nresponse += '\\n_Schedule updated successfully. Is there anything else you need help with?_';\n\nreturn [{ json: { output: response } }];"
      },
      "id": "c0da8d90-8558-4b4b-9622-fdb1bc5cb97a",
