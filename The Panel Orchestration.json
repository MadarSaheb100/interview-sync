      "id": "b9e41368-5c80-4571-83ab-db384360afa3",
      "name": "Set - Super Day Inputs"
    },
    {
      "parameters": {
        "jsCode": "const candidates = $json.candidates;\nconst interviewers = $json.interviewers;\nconst rooms = $json.rooms;\n\nlet schedule = [];\n\ncandidates.forEach((candidate, index) => {\n  const interviewer = interviewers[index % interviewers.length];\n  const room = rooms[index % rooms.length];\n\n  schedule.push({\n    candidate: candidate.name,\n    interviewer: interviewer.name,\n    room: room.id,\n    round: \"R1\",\n    time: \"10:00\"\n  });\n\n  schedule.push({\n    candidate: candidate.name,\n    interviewer: interviewer.name,\n    room: room.id,\n    round: \"R2\",\n    time: \"11:00\"\n  });\n\n  schedule.push({\n    candidate: candidate.name,\n    interviewer: interviewer.name,\n    room: room.id,\n    round: \"R3\",\n    time: \"12:00\"\n  });\n});\n\nreturn [{ json: { schedule } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "bed74f23-cb7a-46c4-b0f3-40a9f011be11",
      "name": "Code - Generate Schedule"
    },
    {
      "parameters": {
        "jsCode": "const schedule = $json.schedule;\n\nlet conflicts = [];\n\nschedule.forEach(slot => {\n  if (\n    slot.candidate === \"Priya Sharma\" &&\n    slot.time === \"13:00\"\n  ) {\n    conflicts.push({\n      type: \"PRAYER_CONFLICT\",\n      message: \"Priya unavailable at 1 PM\"\n    });\n  }\n});\n\nreturn [\n  {\n    json: {\n      schedule,\n      conflicts,\n      valid: conflicts.length === 0\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
