    },
    {
      "parameters": {
        "jsCode": "const schedule = $json.schedule;\n\nreturn schedule.map(slot => ({\n  json: {\n    to: slot.candidate,\n    message: `Hi ${slot.candidate}, your ${slot.round} is scheduled at ${slot.time} with ${slot.interviewer} in Room ${slot.room}`\n  }\n}));"
      },
